# ─────────────────────────────────────────────────────────────────────────────
# LLM 공급자 설정 (OpenAI 호환 /chat/completions). 이 파일을 '.env' 로 복사해 값을 채우세요.
#   cp .env.example .env      (Windows: copy .env.example .env)
# .env 는 .gitignore 됩니다(키/사설주소 유출 방지). 미설정 시 아래 기본값(로컬 LM Studio) 사용.
#
# 프로그램은 LLM 없이도 동작합니다(구조/휴리스틱). LLM 은 '결정적 매칭 실패 시 폴백'에만 쓰이며,
# 엔드포인트가 안 닿으면 자동으로 휴리스틱으로 되돌아갑니다.
# ─────────────────────────────────────────────────────────────────────────────

# ── 언어 / Language (en=English default, ko=한국어) — 설정 메뉴에서도 바꿀 수 있음 ──
# (Change in-app: Settings → Language. Source strings are Korean; en is an overlay.)
LANG=en

# ── (A) 로컬 LM Studio / Ollama 등 (기본, 키 불필요) ──────────────────────────
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=

# ── (B) OpenAI (빠르고 똑똑함, 유료) ─ 위 3줄 대신 아래처럼 ───────────────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-여기에_키

# ── (C) OpenRouter (Qwen/Claude/Gemini 등 다양한 모델을 한 키로) ──────────────
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=qwen/qwen-2.5-72b-instruct
# LLM_API_KEY=sk-or-여기에_키

# ── (D) Together / Groq / 기타 OpenAI 호환 게이트웨이도 동일 방식 ─────────────
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_MODEL=Qwen/Qwen2.5-72B-Instruct-Turbo
# LLM_API_KEY=여기에_키

# ─────────────────────────────────────────────────────────────────────────────
# 공유 레시피 레지스트리(메뉴 '레시피 → 검색·적용/공유'). 기본값은 이미 이 프로젝트 자신
# (Sovereign-Scraper repo 의 recipes/shared/registry/) 을 가리키므로 별도 설정 없이 바로 동작한다.
#   · RAW = index.json/recipes 를 HTTPS 로 받는 raw 베이스(끝 / 권장). 인증/ git 불필요(읽기 전용).
#   · WEB = 공유(올리기) 시 브라우저로 열 repo 주소(업로드/PR 페이지 유도).
# 자기 fork 로 별도 레지스트리를 운영하고 싶을 때만 아래를 그 repo 주소로 바꾸세요.
# RECIPE_REGISTRY_RAW=https://raw.githubusercontent.com/<계정>/<내 fork>/main/recipes/shared/registry/
# RECIPE_REGISTRY_WEB=https://github.com/<계정>/<내 fork>
